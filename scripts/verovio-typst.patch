+bool Resources::InitFontsFromZip(ZipFileReader &zipFile)
+{
+    m_cachedGlyph.reset();
+    m_loadedFonts.clear();
+
+    if (!LoadFont(BRAVURA, &zipFile)) LogError("Bravura font could not be loaded.");
+    if (!LoadFont("Gootville", &zipFile)) LogError("Gootville font could not be loaded.");
+    if (!LoadFont(LEIPZIG, &zipFile)) LogError("Leipzig font could not be loaded.");
+    if (!LoadFont("Leland", &zipFile)) LogError("Leland font could not be loaded.");
+    if (!LoadFont("Petaluma", &zipFile)) LogError("Petaluma font could not be loaded.");
+
+    m_defaultFontName = LEIPZIG;
+    m_currentFontName = m_defaultFontName;
+    m_fallbackFontName = m_defaultFontName;
+
+    // Load text fonts from zip
+    struct TextFontInfo {
+        StyleAttributes style;
+        std::string fileName;
+        bool mandatory;
+    };
+    TextFontInfo textFonts[] = {
+        { k_defaultStyle, "Times", true },
+        { { FONTWEIGHT_bold, FONTSTYLE_normal }, "Times-bold", false },
+        { { FONTWEIGHT_bold, FONTSTYLE_italic }, "Times-bold-italic", false },
+        { { FONTWEIGHT_normal, FONTSTYLE_italic }, "Times-italic", false }
+    };
+
+    for (const auto &tf : textFonts) {
+        std::string path = "text/" + tf.fileName + ".xml";
+        if (!zipFile.HasFile(path)) {
+            if (tf.mandatory) {
+                LogError("Text font could not be initialized.");
+                return false;
+            }
+            continue;
+        }
+        std::string content = zipFile.ReadTextFile(path);
+        pugi::xml_document doc;
+        if (!doc.load_string(content.c_str())) continue;
+
+        pugi::xml_node root = doc.first_child();
+        if (!root.attribute("units-per-em")) continue;
+
+        const int unitsPerEm = root.attribute("units-per-em").as_int();
+        if (!m_textFont.contains(tf.style)) {
+            m_textFont[tf.style] = {};
+        }
+        GlyphTable &table = m_textFont.at(tf.style);
+        for (pugi::xml_node g = root.child("g"); g; g = g.next_sibling("g")) {
+            if (!g.attribute("c")) continue;
+            char32_t code = (char32_t)strtol(g.attribute("c").value(), NULL, 16);
+            Glyph glyph(unitsPerEm);
+            float x = 0, y = 0, w = 0, h = 0;
+            if (g.attribute("x")) x = g.attribute("x").as_float();
+            if (g.attribute("y")) y = g.attribute("y").as_float();
+            if (g.attribute("w")) w = g.attribute("w").as_float();
+            if (g.attribute("h")) h = g.attribute("h").as_float();
+            glyph.SetBoundingBox(x, y, w, h);
+            if (g.attribute("h-a-x")) glyph.SetHorizAdvX(g.attribute("h-a-x").as_float());
+            table[code] = glyph;
+        }
+    }
+
+    m_currentStyle = k_defaultStyle;
+    return true;
+}
+
+void Resources::AddLoadedFont(const std::string &name, GlyphTable &&table, bool isFallback)
+{
+    LoadedFont font(name, isFallback);
+    font.GetGlyphTableForModification() = std::move(table);
+    m_loadedFonts.insert(std::pair<std::string, LoadedFont>(name, std::move(font)));
+}
+
+void Resources::AddTextFont(const StyleAttributes &style, GlyphTable &&table)
+{
+    m_textFont[style] = std::move(table);
+}
+
+void Resources::SetDefaultFont(const std::string &name)
+{
+    m_defaultFontName = name;
+    m_currentFontName = name;
+    m_fallbackFontName = name;
+    m_currentStyle = { FONTWEIGHT_normal, FONTSTYLE_normal };
+}
